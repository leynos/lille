{
  "config": {
    "MD004": { "style": "dash" },
    "MD010": { "code_blocks": false },
    "MD013": {
      "line_length": 80,
      "code_block_line_length": 120,
      "tables": false,
      "headings": false
    },
    "MD029": { "style": "ordered" }
  },
  "ignores": [
    "**/.venv/**",
    "**/node_modules/**",
    "**/target/**",
    // Vendored upstream crate fork; not subject to this repo's Markdown style.
    "third_party/feldera-size-of/**"
  ]
}
